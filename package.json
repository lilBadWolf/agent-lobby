{
  "name": "agent-lobby",
  "private": true,
  "version": "0.5.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:e2e:pong": "playwright test e2e/pong-two-users.spec.ts",
    "test:e2e:pong:headed": "playwright test e2e/pong-two-users.spec.ts --headed",
    "test:e2e:pong:debug": "playwright test e2e/pong-two-users.spec.ts --debug",
    "test:e2e:pong:observe": "playwright test e2e/pong-observe.spec.ts --headed",
    "test:e2e:battleship": "playwright test e2e/battleship-two-users.spec.ts",
    "test:e2e:battleship:observe": "playwright test e2e/battleship-observe.spec.ts --headed",
    "test:games": "vitest run src/components/__tests__/PongGame.multiplayer.spec.ts src/components/__tests__/BattleshipGame.multiplayer.spec.ts",
    "test:release-smoke": "npm run test:games",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "markdown-it": "^14.0.2",
    "mqtt": "^5.14.1",
    "node-emoji": "^2.2.0",
    "peerjs": "^1.5.5",
    "three": "^0.184.0",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/peerjs": "^0.0.30",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
