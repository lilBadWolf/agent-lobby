{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-lobby",
  "version": "0.1.2",
  "identifier": "com.thecompanyofwolves.agent-lobby",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AGENT // LOBBY",
        "decorations": false,
        "transparent": true,
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/lilBadWolf/agent-lobby/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3QkMxMzU4NDM5NUZFMzIKUldReS9wVkRXQk84VjhNckRnT1VMYmh1SnQwWHZkRlRnSXhJd0lvMWlTNDBkTWd5WHNIeGlFcTUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "The Company of Wolves",
    "linux": {
      "deb": {
        "depends": ["libgtk-3-0", "libwebkit2gtk-4.0-37"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
      "macOS": {
        "entitlements": "entitlements.plist",
        "infoPlist": "Info.plist"
      }
  }
}
