{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-lobby",
  "version": "0.1.0",
  "identifier": "com.thecompanyofwolves.agent-lobby",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AGENT // LOBBY",
        "decorations": false,
        "transparent": true,
        "width": 800,
        "height": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png"
    ],
      "macOS": {
        "entitlements": "entitlements.plist",
        "infoPlist": "Info.plist"
      }
  }
}
