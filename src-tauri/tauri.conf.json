{
  "$schema": "https://tauri.app",
  "productName": "agent-lobby",
  "version": "0.2.3",
  "identifier": "com.thecompanyofwolves.agent-lobby",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: wss: ws: http://localhost:* http://127.0.0.1:* https://ipc.localhost http://ipc.localhost https://api.twitch.tv https://www.youtube.com; script-src 'self' https://www.youtube.com https://ytimg.com; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com https://player.twitch.tv; style-src 'self' 'unsafe-inline'; img-src * data: blob: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; worker-src 'self' blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }

  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/lilBadWolf/agent-lobby/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3QkMxMzU4NDM5NUZFMzIKUldReS9wVkRXQk84VjhNckRnT1VMYmh1SnQwWHZkRlRnSXhJd0lvMWlTNDBkTWd5WHNIeGlFcTUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "The Company of Wolves",
    "linux": {
      "deb": {
        "depends": ["libgtk-3-0", "libwebkit2gtk-4.0-37"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
